<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".activity.CategoryActivity">

<!--    top-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/back_icon"
            android:layout_marginHorizontal="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/arrow_back_24px"/>
        <TextView
            android:layout_weight="3"
            android:layout_gravity="center"
            android:textAppearance="@style/TextAppearance.KineticArchitect.BodyMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            />
        <ImageView
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/account_circle_24px"/>
    </LinearLayout>




 <androidx.core.widget.NestedScrollView
     android:layout_weight="1"
     android:layout_width="match_parent"
     android:layout_height="wrap_content">
     <LinearLayout

         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:orientation="vertical">



         <LinearLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:orientation="vertical"
             android:paddingHorizontal="24dp"
             android:paddingTop="8dp"
             android:paddingBottom="32dp">

             <TextView
                 android:id="@+id/title"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:text="Edit Category"
                 android:fontFamily="@font/manrope"
                 android:textStyle="bold"
                 android:textSize="36sp"
                 android:textColor="#173600"
                 android:letterSpacing="-0.02"
                 android:lineSpacingMultiplier="1.05" />

             <TextView
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="6dp"
                 android:text="Refine your workflow workspace and kinetic energy."
                 android:fontFamily="@font/inter"
                 android:textSize="14sp"
                 android:textColor="#41484d"
                 android:lineSpacingMultiplier="1.4" />

         </LinearLayout>

         <!-- ── CATEGORY NAME ────────────────────────────── -->
         <LinearLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:orientation="vertical"
             android:paddingHorizontal="24dp"
             android:paddingBottom="28dp">

             <TextView
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_marginBottom="10dp"
                 android:text="Category Name"
                 android:fontFamily="@font/manrope"
                 android:textStyle="bold"
                 android:textSize="15sp"
                 android:textColor="#191c1e" />

             <!-- Input field: surface_container_highest bg   -->
             <com.google.android.material.textfield.TextInputLayout
                 android:id="@+id/tilCategoryName"
                 style="@style/Widget.KineticArchitect.TextInput"
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 app:boxCornerRadiusTopStart="12dp"
                 app:boxCornerRadiusTopEnd="12dp"
                 app:boxCornerRadiusBottomStart="12dp"
                 app:boxCornerRadiusBottomEnd="12dp">

                 <com.google.android.material.textfield.TextInputEditText
                     android:id="@+id/etCategoryName"
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:padding="18dp"
                     android:fontFamily="@font/inter"
                     android:textSize="16sp"
                     android:textColor="#191c1e"
                     android:inputType="textCapSentences"
                     android:background="@null" />

             </com.google.android.material.textfield.TextInputLayout>

             <TextView
                 android:id="@+id/tvCategoryNameError"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_marginBottom="5dp"
                 android:text="Category Name is required"
                 android:fontFamily="@font/manrope"
                 android:textSize="12sp"
                 android:visibility="gone"
                 android:textColor="?attr/colorError" />
         </LinearLayout>

         <!-- ── BRAND COLOR ──────────────────────────────── -->
         <LinearLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:orientation="vertical"
             android:paddingHorizontal="24dp"
             android:paddingBottom="28dp">

             <TextView
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:text="Brand Color"
                 android:layout_marginBottom="12dp"
                 android:textStyle="bold"
                 android:textSize="15sp"
                 android:textColor="#191c1e"/>

             <!-- Selected color preview -->
             <View
                 android:id="@+id/viewSelectedColor"
                 android:layout_width="match_parent"
                 android:layout_height="50dp"
                 android:background="#173600"
                 android:layout_marginBottom="12dp"/>

             <!-- Button to open picker -->
             <com.google.android.material.button.MaterialButton
                 android:id="@+id/btnPickColor"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:text="Choose Color"/>
         </LinearLayout>

     </LinearLayout>


 </androidx.core.widget.NestedScrollView>


    <!-- ══════════════════════════════════════════════════════ -->
    <!-- BOTTOM ACTION BAR — pinned above nav bar               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#f8f9fb"
        android:paddingHorizontal="24dp" >

        <!-- Cancel + Save row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Cancel (ghost text button) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.KineticArchitect.Button.Ghost"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Cancel"
                android:textSize="15sp"
                android:textColor="#2a657e"
                app:strokeColor="@null"
                app:strokeWidth="0dp" />

            <!-- Save Category (primary filled) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActionCategory"
                style="@style/Widget.KineticArchitect.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.6"
                android:text="Save Category"
                android:textSize="15sp"
                android:textColor="#ffffff"
                android:backgroundTint="#173600" />

        </LinearLayout>

        <!-- Delete Category (destructive text button) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Delete Category"
            android:textColor="#ba1a1a"
            android:textSize="14sp"
            android:fontFamily="@font/inter"
            app:iconGravity="start"
            app:iconPadding="6dp" />

    </LinearLayout>

</LinearLayout>