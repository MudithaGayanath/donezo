<?xml version="1.0" encoding="utf-8"?>
<!--
    item_category_skeleton.xml
    Shimmer skeleton placeholder — mirrors item_category.xml structure
    Animate all views tagged with shimmer_target using anim/shimmer.xml
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="#ffffff">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Color strip skeleton -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@drawable/bg_skeleton" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Row 1: circle + name block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- Avatar circle -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_skeleton_circle" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Name line -->
                    <View
                        android:layout_width="140dp"
                        android:layout_height="14dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_skeleton" />

                    <!-- Sub-label line -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_skeleton" />

                </LinearLayout>

                <!-- Menu icon placeholder -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_skeleton_circle" />

            </LinearLayout>

            <!-- Description lines -->
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_skeleton" />

            <View
                android:layout_width="200dp"
                android:layout_height="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_skeleton" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <!-- Chip -->
                <View
                    android:layout_width="100dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_skeleton_pill" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Percentage label -->
                <View
                    android:layout_width="36dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton" />

            </LinearLayout>

            <!-- Progress bar skeleton -->
            <View
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:background="@drawable/bg_skeleton_pill" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>